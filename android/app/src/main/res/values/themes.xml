<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Minimal Android theme for the splash/launch window.
        The actual UI theme is handled by Compose (ui/theme/Theme.kt).
        We only need this for the Activity window background before Compose loads.
    -->
    <style name="Theme.ClaudeManager" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>
